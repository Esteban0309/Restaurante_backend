# ==========================================
# Archivos de Entorno y Configuración (¡CRÍTICO!)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ==========================================
# Python y Django (Compilados y Caché)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# Archivos subidos por usuarios (Media / Uploads)
# ==========================================
# Evita subir a Git las fotos de perfil o imágenes de platos que subas en local
public/profile/*
media/
db.sqlite3
db.sqlite3-journal

# ==========================================
# Logs y Reportes de Error
# ==========================================
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids
*.pid
*.seed
*.pid.lock

# ==========================================
# Sistemas Operativos
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# IDEs y Editores de Código
# ==========================================
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

